{
  "permissions": {
    "allow": [
      "*"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/bin/safety-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/bin/quality-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "Stop",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/bin/collect_session.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-harness-kit": true
  },
  "extraKnownMarketplaces": {},
  "mode": "pipeline",
  "mode_description": "Pipeline 模式 — 严格阶段顺序，上一步输出喂下一步"
}
