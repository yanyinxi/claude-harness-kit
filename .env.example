# Claude Team Kit - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Project root directory (auto-detected, usually no need to set)
# CLAUDE_PROJECT_DIR=/path/to/project

# Plugin root directory (auto-detected, usually no need to set)
# CLAUDE_PLUGIN_ROOT=/path/to/claude-team-kit

# Session identifier (auto-generated, usually no need to set)
# CLAUDE_SESSION_ID=session-xxx

# Optional: External API keys (if needed by certain skills)
# OPENAI_API_KEY=sk-xxx
# GITHUB_TOKEN=ghp_xxx
