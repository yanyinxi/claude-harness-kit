{
  "description": "Claude Harness Kit - Multi-agent collaboration, Skills, Self-evolution",
  "disabled": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/bin/safety-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/bin/quality-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/bin/memory-inject.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash hooks/bin/check-update.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}