{
  "description": "默认模式 — 标准安全 + 质量建议，不强制 TDD",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash hooks/bin/safety-check.sh", "timeout": 5 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "bash hooks/bin/quality-gate.sh", "timeout": 10 }]
      }
    ]
  }
}
