{
  "description": "Ralph 模式 — TDD 强制 + 严格质量门禁，实现代码必须有测试文件",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash hooks/bin/safety-check.sh", "timeout": 5 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "bash hooks/bin/tdd-check.sh", "timeout": 5 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "bash hooks/bin/quality-gate.sh", "timeout": 10 }]
      }
    ],
    "Stop": [
      {
        "matcher": "Stop",
        "hooks": [{ "type": "command", "command": "python3 hooks/bin/collect_session.py", "timeout": 10 }]
      }
    ]
  }
}
