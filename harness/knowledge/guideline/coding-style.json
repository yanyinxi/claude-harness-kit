  {
    "id": "guideline-009",
    "type": "guideline",
    "name": "安全编码规范",
    "description": "OWASP Top 10 防护措施",
    "maturity": "validated",
    "content": {
      "injection": {
        "rule": "所有数据库/系统命令必须参数化",
        "patterns": ["' OR '1'='1", "$(whoami)", "`<script>`"]
      },
      "xss": {
        "rule": "用户输入必须转义输出",
        "patterns": ["<script>", "javascript:", "onerror="]
      },
      "csrf": {
        "rule": "状态变更请求必须验证 CSRF token"
      },
      "sensitive": {
        "rule": "敏感数据不得硬编码或日志输出",
        "patterns": ["password", "token", "secret", "api_key"]
      }
    },
    "created_at": "2026-05-10",
    "last_used_at": null,
    "usage_count": 0,
    "project_count": 0
  },
  {
    "id": "guideline-010",
    "type": "guideline",
    "name": "并发安全规范",
    "description": "多线程/异步场景下的安全编码",
    "maturity": "validated",
    "content": {
      "principles": [
        "共享状态必须加锁保护",
        "避免死锁（按固定顺序获取锁）",
        "线程池使用有界队列",
        "超时设置防止永久阻塞"
      ],
      "python_specific": [
        "asyncio 不使用 blocking IO",
        "多进程共享数据用 multiprocessing.Queue",
        "线程安全用 threading.Lock 或 asyncio.Lock"
      ]
    },
    "created_at": "2026-05-10",
    "last_used_at": null,
