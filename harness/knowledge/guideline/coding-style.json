  {
    "id": "guideline-008",
    "type": "guideline",
    "name": "数据库规范",
    "description": "数据库设计和查询规范",
    "maturity": "draft",
    "content": {
      "naming": [
        "表名使用 snake_case，复数形式",
        "字段名使用 snake_case",
        "主键命名: id",
        "外键命名: {table}_id"
      ],
      "queries": [
        "禁止字符串拼接 SQL，必须参数化",
        "禁止 select *，明确列出字段",
        "查询必须有索引支持",
        "大批量操作需要分批"
      ],
      "migrations": [
        "每个 migration 独立可逆",
        "先在测试环境验证",
        "记录回滚方案"
      ]
