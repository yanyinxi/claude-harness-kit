    "name": "API 设计规范",
    "description": "RESTful API 设计和响应格式规范",
    "maturity": "validated",
    "content": {
      "url_design": [
        "使用名词而非动词",
        "使用 kebab-case",
        "嵌套资源不超过 2 层",
        "版本号放 URL 前缀"
      ],
      "response_format": {
        "success": {
          "code": 0,
          "data": {},
          "message": "success"
        },
        "error": {
          "code": 40001,
          "message": "错误描述",
          "trace_id": "xxx"
        }
      },
      "status_codes": {
        "200": "成功",
        "201": "创建成功",
        "400": "请求参数错误",
        "401": "未认证",
        "403": "无权限",
        "404": "资源不存在",
        "500": "服务器错误"
      }
    },
